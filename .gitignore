secrets.yaml
*.pem
*.key

# --- Data (gitignored — see data/README.md) ---
data/*.csv
data/*.parquet
data/*.zip
data/*.tsv
!data/README.md

# --- Trained-model artifacts (regenerated by `python -m model.train`) ---
model/artifacts/*.joblib
model/artifacts/*.pkl
model/artifacts/*.json
model/artifacts/*.parquet
!model/artifacts/.gitkeep

# --- Generated monitoring reports ---
monitoring/reports/*.html
monitoring/reports/*.json
!monitoring/reports/.gitkeep

